generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(uuid())
  name        String
  email       String          @unique
  password    String
  defaultRole String          @default("AUXILIAR")
  isAdmin     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  membership  TeamMembership?
  playerStats PlayerStat[]
}

model Team {
  id            String           @id @default(uuid())
  name          String           @unique
  logoUrl       String?
  city          String?
  state         String?          @default("RS")
  phone         String?
  sex           String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  awayGames     Game[]           @relation("AwayTeam")
  homeGames     Game[]           @relation("HomeTeam")
  gym           Gym?
  sentMessages  Message[]        @relation("SentMessages")
  notifications Notification[]
  registrations Registration[]
  standings     Standing[]
  members       TeamMembership[]
  playerStats   PlayerStat[]
  athletes      Athlete[]
  seasonRankings SeasonRanking[]
  bidEntriesFrom AthleteBidEntry[] @relation("BidTeamFrom")
  bidEntriesTo   AthleteBidEntry[] @relation("BidTeamTo")
}

model Gym {
  id           String  @id @default(uuid())
  name         String
  address      String
  city         String
  capacity     Int
  availability String
  canHost      Boolean @default(true)
  teamId       String  @unique
  team         Team    @relation(fields: [teamId], references: [id])
}

model Championship {
  id             String                 @id @default(uuid())
  name           String
  year           Int                    @default(2026)
  description    String?
  sex            String                 @default("masculino")
  format         String                 @default("todos_contra_todos")
  turns          Int                    @default(1)
  phases         Int                    @default(1)
  fieldControl   String                 @default("alternado")
  tiebreakers    String                 @default("pontos,saldo,confronto_direto,pontos_marcados")
  hasRelegation  Boolean                @default(false)
  relegationDown Int                    @default(0)
  promotionUp    Int                    @default(0)
  hasPlayoffs    Boolean                @default(false)
  playoffTeams   Int                    @default(4)
  playoffFormat  String                 @default("melhor_de_1")
  hasThirdPlace  Boolean                @default(true)
  hasBlocks      Boolean                @default(false)
  minTeamsPerCat Int                    @default(3)
  startDate      DateTime?
  endDate        DateTime?
  regDeadline    DateTime               @default(now())
  status         String                 @default("DRAFT")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  numberOfCourts              Int                    @default(1)
  dayStartTime                String                 @default("08:00")
  regularDayEndTime           String                 @default("19:00")
  extendedDayEndTime          String                 @default("20:30")
  slotDurationMinutes         Int                    @default(75)
  minRestSlotsPerTeam         Int                    @default(1)
  maxGamesPerTeamPerDay       Int                    @default(2)
  scheduleOptimizationMode    String                 @default("less_travel")
  blockFormat                 String                 @default("SAT_SUN")
  isSimulation                Boolean                @default(false)
  blocks         Block[]
  categories     ChampionshipCategory[]
  documents      Document[]
  games          Game[]
  registrations  Registration[]
  bidEntries     AthleteBidEntry[]
}

model ChampionshipCategory {
  id             String                 @id @default(uuid())
  name           String
  championshipId String
  isViable       Boolean                @default(false)
  championship   Championship           @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  games          Game[]
  registrations  RegistrationCategory[]
  standings      Standing[]

  @@unique([championshipId, name])
}

model Registration {
  id             String                 @id @default(uuid())
  championshipId String
  teamId         String
  status         String                 @default("PENDING")
  observations   String?
  registeredAt   DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  coachName      String?
  coachPhone     String?
  coachEmail     String?
  coachMultiTeam Boolean                @default(false)

  // Gym Hosting / Sede
  canHost        Boolean                @default(false)
  gymName        String?
  gymAddress     String?
  gymCity        String?
  gymMapsLink    String?

  blockedDates   BlockedDate[]
  athletePlayers AthleteCategory[]
  team           Team                   @relation(fields: [teamId], references: [id])
  championship   Championship           @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  categories     RegistrationCategory[]

  @@unique([championshipId, teamId])
}

model RegistrationCategory {
  id             String               @id @default(uuid())
  registrationId String
  categoryId     String
  category       ChampionshipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  registration   Registration         @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, categoryId])
}

model BlockedDate {
  id             String       @id @default(uuid())
  registrationId String
  startDate      DateTime
  endDate        DateTime
  reason         String?
  affectsAllCats Boolean      @default(false)
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([startDate, endDate])
}

model AthleteCategory {
  id             String       @id @default(cuid())
  registrationId String
  athleteName    String
  athleteDoc     String?
  categoryIds    String
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model Block {
  id             String       @id @default(uuid())
  name           String
  championshipId String
  categories     String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  games          Game[]
}

model Game {
  id             String               @id @default(uuid())
  championshipId String
  categoryId     String
  blockId        String?
  homeTeamId     String
  awayTeamId     String
  phase          Int                  @default(1)
  round          Int?                 @default(1)
  dateTime       DateTime
  altDateTime    DateTime?
  location       String
  city           String
  court          String?
  venue          String?
  isReturn       Boolean              @default(false)
  period         String?
  status         String               @default("SCHEDULED")
  homeScore      Int?
  awayScore      Int?
  wasRescheduled Boolean              @default(false)
  rescheduleReason String?
  blockedByTeamId String?
  createdAt      DateTime             @default(now())
  awayTeam       Team                 @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam       Team                 @relation("HomeTeam", fields: [homeTeamId], references: [id])
  block          Block?               @relation(fields: [blockId], references: [id])
  category       ChampionshipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  championship   Championship         @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  playerStats    PlayerStat[]
  refereeAssignments RefereeAssignment[]
}

model Standing {
  id         String               @id @default(uuid())
  teamId     String
  categoryId String
  played     Int                  @default(0)
  wins       Int                  @default(0)
  losses     Int                  @default(0)
  draws      Int                  @default(0)
  points     Int                  @default(0)
  pointsFor  Int                  @default(0)
  pointsAg   Int                  @default(0)
  pointsAgainst Int               @default(0)
  diff       Int                  @default(0)
  updatedAt  DateTime             @updatedAt
  category   ChampionshipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  team       Team                 @relation(fields: [teamId], references: [id])

  @@unique([teamId, categoryId])
}

model Athlete {
  id         String   @id @default(uuid())
  name       String
  birthDate  DateTime?
  document   String?
  sex        String?
  photoUrl   String?
  status     String   @default("ACTIVE")
  teamId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  team       Team?    @relation(fields: [teamId], references: [id])
  cards      AthleteIdCard[]
  bidEntries AthleteBidEntry[]

  @@index([teamId])
  @@index([document])
}

model AthleteIdCard {
  id         String   @id @default(uuid())
  athleteId  String
  cardNumber String   @unique
  qrToken    String   @unique
  issuedAt   DateTime @default(now())
  expiresAt  DateTime?
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
}

model AthleteBidEntry {
  id             String   @id @default(uuid())
  athleteId      String
  championshipId String?
  teamFromId     String?
  teamToId       String?
  type           String   @default("REGISTRATION")
  status         String   @default("PENDING")
  reason         String?
  createdAt      DateTime @default(now())
  athlete        Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  championship   Championship? @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  teamFrom       Team?    @relation("BidTeamFrom", fields: [teamFromId], references: [id], onDelete: SetNull)
  teamTo         Team?    @relation("BidTeamTo", fields: [teamToId], references: [id], onDelete: SetNull)

  @@index([athleteId])
  @@index([championshipId])
}

model Referee {
  id            String   @id @default(uuid())
  name          String
  licenseNumber String?
  phone         String?
  email         String?
  city          String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assignments   RefereeAssignment[]
}

model RefereeAssignment {
  id         String   @id @default(uuid())
  gameId     String
  refereeId  String
  role       String   @default("MAIN")
  status     String   @default("ASSIGNED")
  notes      String?
  createdAt  DateTime @default(now())
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  referee    Referee  @relation(fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([refereeId])
}

model Sponsor {
  id         String   @id @default(uuid())
  name       String
  logoUrl    String?
  websiteUrl String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  clicks     SponsorClick[]
}

model SponsorClick {
  id         String   @id @default(uuid())
  sponsorId  String
  source     String?
  referrer   String?
  createdAt  DateTime @default(now())
  sponsor    Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
}

model NewsPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverUrl    String?
  status      String   @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VideoPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  videoUrl    String
  coverUrl    String?
  status      String   @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeasonRanking {
  id        String   @id @default(uuid())
  teamId    String
  season    Int
  points    Int      @default(0)
  wins      Int      @default(0)
  losses    Int      @default(0)
  games     Int      @default(0)
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, season])
  @@index([season])
}

model Document {
  id             String       @id @default(uuid())
  name           String
  type           String
  format         String
  url            String?
  championshipId String
  createdAt      DateTime     @default(now())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  teamId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  content    String
  fromTeamId String?
  fromAdmin  Boolean  @default(false)
  createdAt  DateTime @default(now())
  team       Team?    @relation("SentMessages", fields: [fromTeamId], references: [id])
}

model Holiday {
  id               String   @id @default(uuid())
  date             DateTime
  name             String
  year             Int
  reason           String?
  isFamilyHoliday  Boolean  @default(false)
}

model TeamMembership {
  id          String    @id @default(uuid())
  userId      String    @unique
  teamId      String
  role        String
  number      Int?
  status      String    @default("PENDING")
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  team        Team      @relation(fields: [teamId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model PlayerStat {
  id        String   @id @default(uuid())
  gameId    String
  teamId    String
  userId    String
  points    Int      @default(0)
  fouls     Int      @default(0)
  
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}
