generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(uuid())
  name        String
  email       String           @unique
  password    String
  defaultRole String           @default("AUXILIAR")
  isAdmin     Boolean          @default(false)
  isFederationSuperAdmin Boolean @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  memberships TeamMembership[]
  playerStats PlayerStat[]
  financialPaymentsCreated FinancialPayment[] @relation("FinancialPaymentCreatedBy")
  financialAuditLogsCreated FinancialAuditLog[] @relation("FinancialAuditLogCreatedBy")
  athleteRegistrationRequestsReviewed   AthleteRegistrationRequest[] @relation("AthleteRegistrationReviewedBy")
  athleteRegistrationRequestsApproved   AthleteRegistrationRequest[] @relation("AthleteRegistrationApprovedBy")
  athleteRegistrationRequestsCbbChecked AthleteRegistrationRequest[] @relation("AthleteRegistrationCbbCheckedBy")
  athleteRegistrationAuditLogsCreated   AthleteRegistrationAuditLog[] @relation("AthleteRegistrationAuditLogCreatedBy")
}

model Team {
  id                  String               @id @default(uuid())
  name                String               @unique
  logoUrl             String?
  city                String?
  state               String?              @default("RS")
  phone               String?
  sex                 String?
  responsible         String?
  totalFeesOwed       Float                @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  // Diretoria
  presidentName       String?
  presidentPhone      String?
  presidentMobile     String?
  presidentEmail      String?
  secretaryName       String?
  secretaryPhone      String?
  secretaryMobile     String?
  secretaryEmail      String?
  financialName       String?
  financialPhone      String?
  financialMobile     String?
  financialEmail      String?
  // Institucional
  cnpj                String?
  website             String?
  instagram           String?
  whatsapp            String?
  observations        String?
  isActive            Boolean              @default(true)
  awayGames           Game[]               @relation("AwayTeam")
  homeGames           Game[]               @relation("HomeTeam")
  gym                 Gym?
  sentMessages        Message[]            @relation("SentMessages")
  notifications       Notification[]
  registrations       Registration[]
  standings           Standing[]
  members             TeamMembership[]
  playerStats         PlayerStat[]
  gameRosters         GameRoster[]
  gameEvents          GameEvent[]
  livePlayerStatLines GamePlayerStatLine[]
  liveTeamStatLines   GameTeamStatLine[]
  athletes            Athlete[]
  seasonRankings      SeasonRanking[]
  bidEntriesFrom      AthleteBidEntry[]    @relation("BidTeamFrom")
  bidEntriesTo        AthleteBidEntry[]    @relation("BidTeamTo")
  financialInvoices   FinancialInvoice[]
  athleteRegistrationRequests AthleteRegistrationRequest[]
  coachStaff          CoachStaff[]
  teamFees            TeamFee[]
  officialRosters     OfficialRoster[]
}

model Gym {
  id           String   @id @default(uuid())
  name         String
  address      String?
  city         String
  state        String   @default("RS")
  capacity     Int?
  courts       Int      @default(1)
  phone        String?
  lat          Float?
  lng          Float?
  observations String?
  availability String?
  canHost      Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  teamId       String?  @unique
  team         Team?    @relation(fields: [teamId], references: [id])

  @@index([city])
}

model Championship {
  id                       String                 @id @default(uuid())
  name                     String
  year                     Int                    @default(2026)
  description              String?
  sex                      String                 @default("masculino")
  format                   String                 @default("todos_contra_todos")
  turns                    Int                    @default(1)
  phases                   Int                    @default(1)
  fieldControl             String                 @default("alternado")
  tiebreakers              String                 @default("pontos,saldo,confronto_direto,pontos_marcados")
  hasRelegation            Boolean                @default(false)
  relegationDown           Int                    @default(0)
  promotionUp              Int                    @default(0)
  hasPlayoffs              Boolean                @default(false)
  playoffTeams             Int                    @default(4)
  playoffFormat            String                 @default("melhor_de_1")
  hasThirdPlace            Boolean                @default(true)
  hasBlocks                Boolean                @default(false)
  minTeamsPerCat           Int                    @default(3)
  startDate                DateTime?
  endDate                  DateTime?
  regDeadline              DateTime               @default(now())
  status                   String                 @default("DRAFT")
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  numberOfCourts           Int                    @default(1)
  dayStartTime             String                 @default("08:00")
  regularDayEndTime        String                 @default("19:00")
  extendedDayEndTime       String                 @default("20:30")
  slotDurationMinutes      Int                    @default(75)
  minRestSlotsPerTeam      Int                    @default(1)
  maxGamesPerTeamPerDay    Int                    @default(2)
  scheduleOptimizationMode String                 @default("less_travel")
  blockFormat              String                 @default("SAT_SUN")
  isSimulation             Boolean                @default(false)
  sanctioning              String                 @default("FGB_OFFICIAL")
  countsForRanking         Boolean                @default(true)
  countsForBidEligibility  Boolean                @default(true)
  sanctionNumber           String?
  modality                 String                 @default("5x5")
  ageRangeMin              Int?
  ageRangeMax              Int?
  allowedWeekdaysJson      String                 @default("[6,0]")
  timeSlotsJson            String                 @default("[]")
  blackoutDatesJson        String                 @default("[]")
  minRestHoursBetweenGames Float                  @default(20)
  maxGamesPerTeamPerWeek   Int                    @default(3)
  homePattern              String                 @default("ALTERNATED")
  maxCategoriesPerDay      Int                    @default(2)
  minAgeGapBetweenGames    Int                    @default(3)
  lunchBreakMinutes        Int                    @default(120)
  afternoonStartTime       String                 @default("13:00")
  fridayEnabled            Boolean                @default(false)
  sharedGymHandlingMode    String                 @default("SEQUENTIAL")
  regulationPdfUrl         String?
  regulationVersion        Int                    @default(1)
  regulationPublishedAt    DateTime?
  publishedAt              DateTime?
  registrationOpenedAt     DateTime?
  technicalCongressDate    DateTime?
  drawDate                 DateTime?
  finishedAt               DateTime?
  blocks                   Block[]
  categories               ChampionshipCategory[]
  documents                Document[]
  games                    Game[]
  registrations            Registration[]
  bidEntries               AthleteBidEntry[]
  financialInvoices        FinancialInvoice[]
  officialRosters          OfficialRoster[]
  externalBlocks           ExternalCompetitionBlock[]
  registrationBlocks       FGBRegistrationBlock[]
  tiebreakerRules          TiebreakerRule[]
  championshipPhases       ChampionshipPhase[]
  tournamentDocuments      TournamentDocument[]
  statusTransitions        ChampionshipStatusTransition[]
}

model ChampionshipCategory {
  id             String                 @id @default(uuid())
  name           String
  championshipId String
  isViable       Boolean                @default(false)
  minBirthYear   Int?
  maxBirthYear   Int?
  modality       String                 @default("5x5")
  championship   Championship           @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  games          Game[]
  registrations  RegistrationCategory[]
  standings      Standing[]
  phaseEntries   ChampionshipPhaseCategory[]

  @@unique([championshipId, name])
}

model Registration {
  id             String   @id @default(uuid())
  championshipId String
  teamId         String
  status         String   @default("PENDING")
  lifecycleState String   @default("SUBMITTED")
  lifecycleVersion Int    @default(0)
  observations   String?
  registeredAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt
  submittedAt    DateTime?
  confirmedAt    DateTime?
  confirmedByUserId String?
  rejectedAt     DateTime?
  rejectedByUserId String?
  rejectionReason String?
  coachName      String?
  coachPhone     String?
  coachEmail     String?
  coachMultiTeam Boolean  @default(false)

  // Gym Hosting / Sede
  canHost     Boolean @default(false)
  gymName     String?
  gymAddress  String?
  gymCity     String?
  gymMapsLink String?

  eligibilityWindowStart DateTime?
  eligibilityWindowEnd   DateTime?
  certNegativaUrl        String?

  blockedDates   BlockedDate[]
  athletePlayers AthleteCategory[]
  fees           RegistrationFee[]
  team           Team                   @relation(fields: [teamId], references: [id])
  championship   Championship           @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  categories     RegistrationCategory[]
  financialInvoices FinancialInvoice[]

  @@unique([championshipId, teamId])
  @@index([championshipId, status])
  @@index([teamId])
  @@index([lifecycleState])
}

model FeeConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  value       Float
  category    String
  description String?
  isActive    Boolean  @default(true)
  appliesFrom DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RegistrationFee {
  id             String       @id @default(uuid())
  registrationId String
  feeKey         String
  feeLabel       String
  quantity       Int          @default(1)
  unitValue      Float
  totalValue     Float
  notes          String?
  status         String       @default("PENDING")
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  financialInvoiceItems FinancialInvoiceItem[]

  @@index([registrationId])
}

model FinancialInvoice {
  id             String   @id @default(uuid())
  number         String   @unique
  teamId         String
  championshipId String?
  registrationId String?
  status         String   @default("DRAFT")
  issueDate      DateTime @default(now())
  dueDate        DateTime?
  subtotalCents  Int      @default(0)
  discountCents  Int      @default(0)
  totalCents     Int      @default(0)
  paidCents      Int      @default(0)
  balanceCents   Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  team           Team          @relation(fields: [teamId], references: [id])
  championship   Championship? @relation(fields: [championshipId], references: [id])
  registration   Registration? @relation(fields: [registrationId], references: [id])
  items          FinancialInvoiceItem[]
  payments       FinancialPayment[]
  auditLogs      FinancialAuditLog[]

  @@index([teamId])
  @@index([championshipId])
  @@index([registrationId])
  @@index([status])
  @@index([dueDate])
  @@index([issueDate])
}

model FinancialInvoiceItem {
  id                String   @id @default(uuid())
  invoiceId         String
  registrationFeeId String?
  feeKey            String?
  description       String
  quantity          Int      @default(1)
  unitValueCents    Int
  totalCents        Int
  sourceType        String   @default("MANUAL")
  createdAt         DateTime @default(now())

  invoice           FinancialInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  registrationFee   RegistrationFee? @relation(fields: [registrationFeeId], references: [id])

  @@index([invoiceId])
  @@index([registrationFeeId])
}

model FinancialPayment {
  id              String   @id @default(uuid())
  invoiceId       String
  amountCents     Int
  method          String   @default("MANUAL")
  status          String   @default("CONFIRMED")
  paidAt          DateTime @default(now())
  reference       String?
  notes           String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  invoice         FinancialInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("FinancialPaymentCreatedBy", fields: [createdByUserId], references: [id])

  @@index([invoiceId])
  @@index([status])
  @@index([paidAt])
}

model FinancialAuditLog {
  id              String   @id @default(uuid())
  invoiceId       String
  action          String
  description     String
  metadataJson    String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  invoice         FinancialInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("FinancialAuditLogCreatedBy", fields: [createdByUserId], references: [id])

  @@index([invoiceId])
  @@index([createdAt])
}

model RegistrationCategory {
  id             String               @id @default(uuid())
  registrationId String
  categoryId     String
  category       ChampionshipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  registration   Registration         @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, categoryId])
}

model BlockedDate {
  id             String       @id @default(uuid())
  registrationId String
  startDate      DateTime
  endDate        DateTime
  reason         String?
  affectsAllCats Boolean      @default(false)
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([startDate, endDate])
}

model AthleteCategory {
  id             String       @id @default(cuid())
  registrationId String
  athleteName    String
  athleteDoc     String?
  categoryIds    String
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model Block {
  id             String       @id @default(uuid())
  name           String
  championshipId String
  categories     String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  games          Game[]
}

model Game {
  id                         String               @id @default(uuid())
  championshipId             String
  categoryId                 String
  blockId                    String?
  homeTeamId                 String
  awayTeamId                 String
  phase                      Int                  @default(1)
  round                      Int?                 @default(1)
  dateTime                   DateTime
  altDateTime                DateTime?
  location                   String
  city                       String
  court                      String?
  venue                      String?
  isReturn                   Boolean              @default(false)
  period                     String?
  status                     String               @default("SCHEDULED")
  liveStatus                 String               @default("SCHEDULED")
  lifecycleState             String               @default("SCHEDULED")
  lifecycleVersion           Int                  @default(0)
  currentPeriod              Int                  @default(0)
  clockDisplay               String?
  homeTimeoutsUsed           Int                  @default(0)
  awayTimeoutsUsed           Int                  @default(0)
  homeTeamFoulsCurrentPeriod Int                  @default(0)
  awayTeamFoulsCurrentPeriod Int                  @default(0)
  isLivePublished            Boolean              @default(false)
  officialReportId           String?
  homeScore                  Int?
  awayScore                  Int?
  attendance                 Int?
  wasRescheduled             Boolean              @default(false)
  rescheduleReason           String?
  blockedByTeamId            String?
  fibaFixtureId              String?
  lastFibaSyncAt             DateTime?
  isHistoricallyLocked       Boolean              @default(false)
  lockedAt                   DateTime?
  lockedByUserId             String?
  lockReason                 String?
  createdAt                  DateTime             @default(now())
  awayTeam                   Team                 @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam                   Team                 @relation("HomeTeam", fields: [homeTeamId], references: [id])
  block                      Block?               @relation(fields: [blockId], references: [id])
  category                   ChampionshipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  championship               Championship         @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  playerStats                PlayerStat[]
  refereeAssignments         RefereeAssignment[]
  liveSessions               GameLiveSession[]
  rosters                    GameRoster[]
  officials                  GameOfficial[]
  events                     GameEvent[]
  playerStatLines            GamePlayerStatLine[]
  teamStatLines              GameTeamStatLine[]
  periodScores               GamePeriodScore[]
  auditLogs                  GameAuditLog[]
  officialReport             GameOfficialReport?

  @@index([championshipId, status])
  @@index([championshipId, dateTime])
  @@index([categoryId, status])
  @@index([dateTime])
  @@index([lifecycleState])
}

model GameLiveSession {
  id                     String      @id @default(uuid())
  gameId                 String
  status                 String      @default("PRE_GAME_READY")
  startedAt              DateTime?
  endedAt                DateTime?
  openedByUserId         String?
  closedByUserId         String?
  notes                  String?
  publicVisibilityStatus String      @default("PRE_GAME")
  currentPeriod          Int         @default(0)
  clockStatus            String      @default("STOPPED")
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  game                   Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  events                 GameEvent[]

  @@index([gameId])
}

model GameRoster {
  id                 String             @id @default(uuid())
  gameId             String
  teamId             String
  coachName          String?
  assistantCoachName String?
  isLocked           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  game               Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team               Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  players            GameRosterPlayer[]

  @@unique([gameId, teamId])
  @@index([gameId])
}

model GameRosterPlayer {
  id             String     @id @default(uuid())
  gameRosterId   String
  athleteId      String
  jerseyNumber   Int?
  isStarter      Boolean    @default(false)
  isCaptain      Boolean    @default(false)
  isAvailable    Boolean    @default(true)
  isOnCourt      Boolean    @default(false)
  isDisqualified Boolean    @default(false)
  status         String     @default("ACTIVE")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  gameRoster     GameRoster @relation(fields: [gameRosterId], references: [id], onDelete: Cascade)
  athlete        Athlete    @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([gameRosterId, athleteId])
  @@index([gameRosterId])
  @@index([athleteId])
}

model GameOfficial {
  id           String   @id @default(uuid())
  gameId       String
  officialType String
  name         String
  refereeId    String?
  role         String
  createdAt    DateTime @default(now())
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  referee      Referee? @relation(fields: [refereeId], references: [id], onDelete: SetNull)

  @@index([gameId])
}

model GameEvent {
  id                 String          @id @default(uuid())
  gameId             String
  liveSessionId      String
  sequenceNumber     Int
  sequence           Int?
  period             Int
  clockTime          String
  clockMs            Int?
  eventType          String
  teamId             String?
  athleteId          String?
  secondaryAthleteId String?
  pointsDelta        Int?
  homeScoreAfter     Int?
  awayScoreAfter     Int?
  payloadJson        String?
  createdByUserId    String?
  createdAt          DateTime        @default(now())
  isCancelled        Boolean         @default(false)
  isReverted         Boolean         @default(false)
  revertedAt         DateTime?
  revertedByUserId   String?
  correctionReason   String?
  correctsEventId     String?
  supersededByEventId String?
  game               Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  liveSession        GameLiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  team               Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  athlete            Athlete?        @relation("GameEventAthlete", fields: [athleteId], references: [id], onDelete: SetNull)
  secondaryAthlete   Athlete?        @relation("GameEventSecondaryAthlete", fields: [secondaryAthleteId], references: [id], onDelete: SetNull)
  correctsEvent      GameEvent?      @relation("GameEventCorrection", fields: [correctsEventId], references: [id], onDelete: SetNull)
  correctedByEvents  GameEvent[]     @relation("GameEventCorrection")

  @@index([gameId, sequenceNumber])
  @@index([liveSessionId])
  @@index([correctsEventId])
  @@index([supersededByEventId])
}

model GamePlayerStatLine {
  id                  String   @id @default(uuid())
  gameId              String
  athleteId           String
  teamId              String
  minutesPlayed       Int      @default(0)
  points              Int      @default(0)
  fouls               Int      @default(0)
  technicalFouls      Int      @default(0)
  assists             Int      @default(0)
  reboundsOffensive   Int      @default(0)
  reboundsDefensive   Int      @default(0)
  reboundsTotal       Int      @default(0)
  steals              Int      @default(0)
  blocks              Int      @default(0)
  turnovers           Int      @default(0)
  twoPtMade           Int      @default(0)
  twoPtAttempted      Int      @default(0)
  threePtMade         Int      @default(0)
  threePtAttempted    Int      @default(0)
  freeThrowsMade      Int      @default(0)
  freeThrowsAttempted Int      @default(0)
  plusMinus              Int?
  isStarter              Boolean  @default(false)
  fouledOut              Boolean  @default(false)
  disqualified           Boolean  @default(false)
  pointsInPaint          Int      @default(0)
  fastBreakPoints        Int      @default(0)
  secondChancePoints     Int      @default(0)
  pointsFromTurnover     Int      @default(0)
  dunks                  Int      @default(0)
  blocksReceived         Int      @default(0)
  foulsTechnical         Int      @default(0)
  fibaIndex              Int      @default(0)
  updatedAt              DateTime @updatedAt
  game                   Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  athlete                Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  team                   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([gameId, athleteId])
  @@index([gameId])
}

model GameTeamStatLine {
  id                  String   @id @default(uuid())
  gameId              String
  teamId              String
  points              Int      @default(0)
  fouls               Int      @default(0)
  timeoutsUsed        Int      @default(0)
  reboundsTotal       Int      @default(0)
  assists             Int      @default(0)
  steals              Int      @default(0)
  turnovers           Int      @default(0)
  blocks              Int      @default(0)
  twoPtMade           Int      @default(0)
  twoPtAttempted      Int      @default(0)
  threePtMade         Int      @default(0)
  threePtAttempted    Int      @default(0)
  freeThrowsMade      Int      @default(0)
  freeThrowsAttempted Int      @default(0)
  updatedAt           DateTime @updatedAt
  game                Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team                Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([gameId, teamId])
  @@index([gameId])
}

model GamePeriodScore {
  id         String   @id @default(uuid())
  gameId     String
  period     Int
  homePoints Int      @default(0)
  awayPoints Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, period])
  @@index([gameId])
}

model GameOfficialReport {
  id                String    @id @default(uuid())
  gameId            String    @unique
  finalHomeScore    Int       @default(0)
  finalAwayScore    Int       @default(0)
  overtimeCount     Int       @default(0)
  officialPdfUrl    String?
  boxScoreJson      String?
  playByPlayJson    String?
  signedOffByUserId String?
  finalizedAt       DateTime?
  createdAt         DateTime  @default(now())
  currentVersion    Int       @default(1)
  game              Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  versions          GameOfficialReportVersion[]
}

model GameOfficialReportVersion {
  id                String    @id @default(uuid())
  reportId          String
  version           Int
  finalHomeScore    Int       @default(0)
  finalAwayScore    Int       @default(0)
  overtimeCount     Int       @default(0)
  officialPdfUrl    String?
  boxScoreJson      String?
  playByPlayJson    String?
  signedOffByUserId String?
  finalizedAt       DateTime?
  reason            String?
  createdByUserId   String?
  createdAt         DateTime  @default(now())
  report            GameOfficialReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
  @@index([reportId])
}

model GameAuditLog {
  id             String   @id @default(uuid())
  gameId         String
  actionType     String
  actorUserId    String?
  targetEntity   String
  targetEntityId String?
  description    String
  metaJson       String?
  createdAt      DateTime @default(now())
  game           Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, createdAt])
}

model Standing {
  id            String               @id @default(uuid())
  teamId        String
  categoryId    String
  played        Int                  @default(0)
  wins          Int                  @default(0)
  losses        Int                  @default(0)
  draws         Int                  @default(0)
  points        Int                  @default(0)
  pointsFor     Int                  @default(0)
  pointsAg      Int                  @default(0)
  pointsAgainst Int                  @default(0)
  diff          Int                  @default(0)
  updatedAt     DateTime             @updatedAt
  category      ChampionshipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  team          Team                 @relation(fields: [teamId], references: [id])

  @@unique([teamId, categoryId])
}

model Athlete {
  id               String               @id @default(uuid())
  name             String
  birthDate        DateTime?
  document         String?
  sex              String?
  photoUrl         String?
  position         String?
  jerseyNumber     Int?
  status           String               @default("ACTIVE")
  federationStatus String               @default("ACTIVE")
  teamId           String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  // Identificação FGB/CBB
  registrationNumber  Int?
  registrationCBB     String?
  registrationPrev    String?
  filiationDate       DateTime?
  // Pessoal
  birthCity           String?
  nationality         String?            @default("Brasileira")
  education           String?
  maritalStatus       String?
  // Documentos
  rg                  String?
  rgOrgan             String?
  rgDate              DateTime?
  cpf                 String?
  // Endereço
  cep                 String?
  state               String?
  city                String?
  address             String?
  addressNum          String?
  addressComp         String?
  // Família
  fatherName          String?
  motherName          String?
  // Contato
  email               String?
  phone               String?
  mobile              String?
  // Esportivo
  height              Float?
  weight              Float?
  shirtNumber         Int?
  // Status FGB
  situation           String             @default("PENDING")
  activatedAt         DateTime?
  activatedBy         String?
  verifiedFgb         Boolean            @default(false)
  verifiedFgbAt       DateTime?
  verifiedFgbBy       String?
  // Documentos digitais
  docCPFUrl           String?
  docRGFrontUrl       String?
  docRGBackUrl        String?
  docBirthCertUrl     String?
  docOtherUrl         String?
  // PM-06.N: CPF dividido + filiação extra
  docCPFFrontUrl      String?
  docCPFBackUrl       String?
  parentContactPhone  String?
  parentContactRole   String?
  notes               String?
  saveWithoutValidation Boolean          @default(false)
  bidPublishedAt   DateTime?
  bidNumber        String?
  team             Team?                @relation(fields: [teamId], references: [id])
  cards            AthleteIdCard[]
  bidEntries       AthleteBidEntry[]
  rosterEntries    GameRosterPlayer[]
  primaryEvents    GameEvent[]          @relation("GameEventAthlete")
  secondaryEvents  GameEvent[]          @relation("GameEventSecondaryAthlete")
  liveStatLines    GamePlayerStatLine[]
  registrationRequests AthleteRegistrationRequest[]
  officialRosterEntries OfficialRosterAthlete[]

  @@index([teamId])
  @@index([document])
  @@index([cpf])
  @@index([situation])
  @@index([verifiedFgb])
}

model AthleteIdCard {
  id         String    @id @default(uuid())
  athleteId  String
  cardNumber String    @unique
  qrToken    String    @unique
  issuedAt   DateTime  @default(now())
  expiresAt  DateTime?
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  athlete    Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
}

model AthleteBidEntry {
  id             String        @id @default(uuid())
  athleteId      String
  championshipId String?
  teamFromId     String?
  teamToId       String?
  type           String        @default("REGISTRATION")
  status         String        @default("PENDING")
  reason         String?
  createdAt      DateTime      @default(now())
  athlete        Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  championship   Championship? @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  teamFrom       Team?         @relation("BidTeamFrom", fields: [teamFromId], references: [id], onDelete: SetNull)
  teamTo         Team?         @relation("BidTeamTo", fields: [teamToId], references: [id], onDelete: SetNull)

  @@index([athleteId])
  @@index([championshipId])
}

model AthleteRegistrationRequest {
  id                       String       @id @default(uuid())
  teamId                   String
  athleteId                String?
  status                   String       @default("DRAFT")
  fullName                 String
  birthDate                DateTime
  documentNumber           String
  documentNumberNormalized String
  motherName               String?
  phone                    String?
  email                    String?
  requestedCategoryLabel   String?
  cbbRegistrationNumber    String?
  // PM-06.N: dados pessoais
  sex                      String?
  nationality              String?
  maritalStatus            String?
  education                String?
  // PM-06.N: documentos
  rg                       String?
  rgOrgan                  String?
  rgDate                   DateTime?
  cpf                      String?
  // PM-06.N: endereço
  cep                      String?
  state                    String?
  city                     String?
  address                  String?
  addressNum               String?
  addressComp              String?
  // PM-06.N: filiação
  fatherName               String?
  parentContactPhone       String?
  parentContactRole        String?
  // PM-06.N: esportivo
  height                   Float?
  weight                   Float?
  position                 String?
  jerseyNumber             Int?
  // PM-06.N: uploads
  photoUrl                 String?
  docCPFFrontUrl           String?
  docCPFBackUrl            String?
  docRGFrontUrl            String?
  docRGBackUrl             String?
  docBirthCertUrl          String?
  docOtherUrl              String?
  cbbCheckStatus           String       @default("PENDING")
  cbbCheckedAt             DateTime?
  cbbCheckedByUserId       String?
  cbbNotes                 String?
  cbbReference             String?
  cbbDocumentMatch         Boolean?
  cbbNameMatch             Boolean?
  cbbBirthDateMatch        Boolean?
  submittedAt              DateTime?
  reviewedAt               DateTime?
  reviewedByUserId         String?
  rejectionReason          String?
  approvedAt               DateTime?
  approvedByUserId         String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  team                     Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  athlete                  Athlete?     @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  cbbCheckedByUser         User?        @relation("AthleteRegistrationCbbCheckedBy", fields: [cbbCheckedByUserId], references: [id], onDelete: SetNull)
  reviewedByUser           User?        @relation("AthleteRegistrationReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  approvedByUser           User?        @relation("AthleteRegistrationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  auditLogs                AthleteRegistrationAuditLog[]

  @@index([teamId])
  @@index([athleteId])
  @@index([status])
  @@index([cbbCheckStatus])
  @@index([documentNumberNormalized])
}

model AthleteRegistrationAuditLog {
  id              String                     @id @default(uuid())
  requestId       String
  action          String
  description     String
  metadataJson    String?
  createdByUserId String?
  createdAt       DateTime                   @default(now())
  request         AthleteRegistrationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdByUser   User?                      @relation("AthleteRegistrationAuditLogCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([createdByUserId])
}

model Referee {
  id                 String              @id @default(uuid())
  name               String
  licenseNumber      String?
  phone              String?
  email              String?
  city               String?
  state              String?
  status             String              @default("ACTIVE")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  // Campos expandidos FGB
  registrationNumber Int?
  sex                String?
  birthDate          DateTime?
  rg                 String?
  cpf                String?
  cep                String?
  address            String?
  motherName         String?
  mobile             String?
  notes              String?
  photoUrl           String?
  isActive           Boolean             @default(true)
  categoryId         String?
  category           RefereeCategory?    @relation(fields: [categoryId], references: [id])
  assignments        RefereeAssignment[]
  gameOfficials      GameOfficial[]
}

model RefereeAssignment {
  id        String   @id @default(uuid())
  gameId    String
  refereeId String
  role      String   @default("MAIN")
  status    String   @default("ASSIGNED")
  notes     String?
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  referee   Referee  @relation(fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([refereeId])
}

model Sponsor {
  id         String         @id @default(uuid())
  name       String
  logoUrl    String?
  websiteUrl String?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  clicks     SponsorClick[]
}

model SponsorClick {
  id        String   @id @default(uuid())
  sponsorId String
  source    String?
  referrer  String?
  createdAt DateTime @default(now())
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
}

model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  content     String
  coverImage  String?
  category    String   @default("Conhecimento")
  tags        String?
  author      String   @default("Redação FGB")
  source      String?
  sourceUrl   String?
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  readTime    Int      @default(5)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isPublished])
  @@index([publishedAt])
  @@index([slug])
}

model NewsPost {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String
  coverUrl        String?
  category        String    @default("NOTICIAS")
  tags            String?
  author          String?
  featured        Boolean   @default(false)
  readingTime     Int?
  metaTitle       String?
  metaDescription String?
  status          String    @default("DRAFT")
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model VideoPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  description String?
  videoUrl    String
  coverUrl    String?
  status      String    @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SeasonRanking {
  id        String   @id @default(uuid())
  teamId    String
  season    Int
  points    Int      @default(0)
  wins      Int      @default(0)
  losses    Int      @default(0)
  games     Int      @default(0)
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, season])
  @@index([season])
}

model Document {
  id             String       @id @default(uuid())
  name           String
  type           String
  format         String
  url            String?
  championshipId String
  createdAt      DateTime     @default(now())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  teamId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  content    String
  fromTeamId String?
  fromAdmin  Boolean  @default(false)
  createdAt  DateTime @default(now())
  team       Team?    @relation("SentMessages", fields: [fromTeamId], references: [id])
}

model Holiday {
  id              String   @id @default(uuid())
  date            DateTime
  name            String
  year            Int
  reason          String?
  isFamilyHoliday Boolean  @default(false)
}

model TeamMembership {
  id          String    @id @default(uuid())
  userId      String
  teamId      String
  role        String
  number      Int?
  status      String    @default("PENDING")
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  team        Team      @relation(fields: [teamId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([teamId])
  @@index([userId, status])
}

model PlayerStat {
  id          String @id @default(uuid())
  gameId      String
  teamId      String
  userId      String
  points      Int    @default(0)
  fouls       Int    @default(0)
  assists     Int    @default(0)
  rebounds    Int    @default(0)
  blocks      Int    @default(0)
  steals      Int    @default(0)
  threePoints Int    @default(0)

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}

// ─── Comissão Técnica ────────────────────────────────────────────────────────

model CoachStaff {
  id              String    @id @default(cuid())
  teamId          String
  team            Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  role            String
  crefi           String?
  sex             String?
  birthDate       DateTime?
  rg              String?
  cpf             String?
  cep             String?
  state           String?
  city            String?
  address         String?
  addressNum      String?
  addressComp     String?
  fatherName      String?
  motherName      String?
  phone           String?
  phone2          String?
  mobile          String?
  notes           String?
  photoUrl        String?
  isActive        Boolean   @default(true)
  situation       String    @default("ACTIVE")
  activatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([teamId])
}

// ─── Categorias de Arbitragem ────────────────────────────────────────────────

model RefereeCategory {
  id           String    @id @default(cuid())
  name         String
  remuneration Float     @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  referees     Referee[]
}

// ─── Listagem Oficial ────────────────────────────────────────────────────────

model OfficialRoster {
  id              String                  @id @default(cuid())
  teamId          String
  team            Team                    @relation(fields: [teamId], references: [id])
  championshipId  String
  championship    Championship            @relation(fields: [championshipId], references: [id])
  categoryId      String?
  season          Int                     @default(2026)
  coachId         String?
  authorized1Id   String?
  authorized2Id   String?
  authorized3Id   String?
  status          String                  @default("DRAFT")
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  pdfUrl          String?
  athletes        OfficialRosterAthlete[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([teamId])
  @@index([championshipId])
}

model OfficialRosterAthlete {
  id          String         @id @default(cuid())
  rosterId    String
  roster      OfficialRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  athleteId   String
  athlete     Athlete        @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  shirtNumber Int?
  position    String?
  order       Int            @default(0)

  @@unique([rosterId, athleteId])
  @@index([rosterId])
}

// ─── Taxas de Clube (simples) ────────────────────────────────────────────────

model TeamFee {
  id           String    @id @default(cuid())
  teamId       String
  team         Team      @relation(fields: [teamId], references: [id])
  type         String
  description  String
  amount       Float
  dueDate      DateTime
  paidAt       DateTime?
  paidAmount   Float?
  paymentProof String?
  status       String    @default("PENDING")
  season       Int       @default(2026)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([teamId, status])
  @@index([season, status])
}

// ─── Competições Externas (Conflito + Exclusividade) ────────────────────────

model ExternalCompetition {
  id              String   @id @default(cuid())
  name            String
  organizer       String
  city            String?
  state           String?
  startDate       DateTime
  endDate         DateTime
  categoriesJson  String   @default("[]")
  gender          String?
  description     String?
  websiteUrl      String?
  logoUrl         String?
  isPublished     Boolean  @default(false)
  season          Int      @default(2026)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  blocks          ExternalCompetitionBlock[]
  registrations   ExternalRegistration[]
}

model ExternalCompetitionBlock {
  id                    String   @id @default(cuid())
  externalCompetitionId String
  externalCompetition   ExternalCompetition @relation(fields: [externalCompetitionId], references: [id], onDelete: Cascade)
  championshipId        String
  championship          Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  categoryId            String?
  createdAt             DateTime @default(now())

  @@unique([externalCompetitionId, championshipId, categoryId])
}

model ExternalRegistration {
  id                    String   @id @default(cuid())
  externalCompetitionId String
  externalCompetition   ExternalCompetition @relation(fields: [externalCompetitionId], references: [id])
  athleteId             String?
  teamId                String?
  categoryId            String?
  declaredBy            String
  status                String   @default("DECLARED")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  blocksGenerated       FGBRegistrationBlock[]

  @@index([athleteId])
  @@index([teamId])
}

model FGBRegistrationBlock {
  id                      String   @id @default(cuid())
  athleteId               String?
  teamId                  String?
  championshipId          String
  championship            Championship @relation(fields: [championshipId], references: [id])
  categoryId              String?
  reason                  String
  externalRegistrationId  String
  externalRegistration    ExternalRegistration @relation(fields: [externalRegistrationId], references: [id])
  isActive                Boolean  @default(true)
  liftedAt                DateTime?
  liftedBy                String?
  liftReason              String?
  createdAt               DateTime @default(now())

  @@index([athleteId, championshipId])
  @@index([teamId, championshipId])
}

model TiebreakerRule {
  id              String       @id @default(cuid())
  championshipId  String
  championship    Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  order           Int
  type            String

  @@index([championshipId, order])
}

model ChampionshipPhase {
  id                 String                       @id @default(cuid())
  championshipId     String
  championship       Championship                 @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  name               String
  order              Int                          @default(0)
  formatType         String                       @default("ROUND_ROBIN")
  formatConfigJson   String                       @default("{}")
  tiebreakerChain    String                       @default("h2h_record,h2h_diff,h2h_for,all_diff,all_for,draw")
  startDate          DateTime?
  endDate            DateTime?
  qualifiesNextCount Int?
  isActive           Boolean                      @default(true)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  groups             ChampionshipGroup[]
  series             GameSeries[]
  categories         ChampionshipPhaseCategory[]

  @@index([championshipId, order])
}

model ChampionshipPhaseCategory {
  id         String                @id @default(cuid())
  phaseId    String
  phase      ChampionshipPhase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  categoryId String
  category   ChampionshipCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([phaseId, categoryId])
}

model ChampionshipGroup {
  id        String              @id @default(cuid())
  phaseId   String
  phase     ChampionshipPhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  name      String
  order     Int                 @default(0)
  createdAt DateTime            @default(now())

  @@index([phaseId])
}

model GameSeries {
  id           String              @id @default(cuid())
  phaseId      String
  phase        ChampionshipPhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  team1Id      String
  team2Id      String
  bestOf       Int                 @default(1)
  homePattern  String              @default("ALTERNATED")
  winnerTeamId String?
  status       String              @default("SCHEDULED")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([phaseId])
  @@index([team1Id])
  @@index([team2Id])
}

model TournamentDocument {
  id             String       @id @default(cuid())
  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  type           String
  title          String
  fileUrl        String
  version        Int          @default(1)
  publishedAt    DateTime     @default(now())
  supersedesId   String?
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([championshipId, type])
}

model ChampionshipStatusTransition {
  id             String       @id @default(cuid())
  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  fromStatus     String
  toStatus       String
  reason         String?
  performedBy    String?
  metadataJson   String?
  createdAt      DateTime     @default(now())

  @@index([championshipId, createdAt])
}

model HistoricalDataAuditLog {
  id                String   @id @default(uuid())
  entityType        String
  entityId          String
  fieldChanged      String?
  oldValue          String?
  newValue          String?
  reason            String
  performedByUserId String
  performedAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedByUserId])
  @@index([performedAt])
}
