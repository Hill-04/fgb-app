generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String          @id @default(uuid())
  name        String
  email       String          @unique
  password    String
  defaultRole String          @default("AUXILIAR")
  isAdmin     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  membership  TeamMembership?
}

model Team {
  id            String           @id @default(uuid())
  name          String           @unique
  logoUrl       String?
  city          String?
  state         String?          @default("RS")
  phone         String?
  sex           String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  awayGames     Game[]           @relation("AwayTeam")
  homeGames     Game[]           @relation("HomeTeam")
  gym           Gym?
  sentMessages  Message[]        @relation("SentMessages")
  notifications Notification[]
  registrations Registration[]
  standings     Standing[]
  members       TeamMembership[]
}

model Gym {
  id           String  @id @default(uuid())
  name         String
  address      String
  city         String
  capacity     Int
  availability String
  canHost      Boolean @default(true)
  teamId       String  @unique
  team         Team    @relation(fields: [teamId], references: [id])
}

model Championship {
  id             String                 @id @default(uuid())
  name           String
  year           Int                    @default(2026)
  description    String?
  sex            String
  format         String                 @default("todos_contra_todos")
  phases         Int                    @default(3)
  minTeamsPerCat Int                    @default(3)
  startDate      DateTime?
  endDate        DateTime?
  regDeadline    DateTime
  status         String                 @default("DRAFT")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  blocks         Block[]
  categories     ChampionshipCategory[]
  documents      Document[]
  games          Game[]
  registrations  Registration[]
}

model ChampionshipCategory {
  id             String                 @id @default(uuid())
  name           String
  championshipId String
  isViable       Boolean                @default(false)
  championship   Championship           @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  games          Game[]
  registrations  RegistrationCategory[]
  standings      Standing[]

  @@unique([championshipId, name])
}

model Registration {
  id             String                 @id @default(uuid())
  championshipId String
  teamId         String
  status         String                 @default("PENDING")
  observations   String?
  registeredAt   DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  blockedDates   BlockedDate[]
  team           Team                   @relation(fields: [teamId], references: [id])
  championship   Championship           @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  categories     RegistrationCategory[]

  @@unique([championshipId, teamId])
}

model RegistrationCategory {
  id             String               @id @default(uuid())
  registrationId String
  categoryId     String
  category       ChampionshipCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  registration   Registration         @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, categoryId])
}

model BlockedDate {
  id             String       @id @default(uuid())
  registrationId String
  date           DateTime
  reason         String?
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Block {
  id             String       @id @default(uuid())
  name           String
  championshipId String
  categories     String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  games          Game[]
}

model Game {
  id             String               @id @default(uuid())
  championshipId String
  categoryId     String
  blockId        String?
  homeTeamId     String
  awayTeamId     String
  phase          Int
  dateTime       DateTime
  altDateTime    DateTime?
  location       String
  city           String
  status         String               @default("SCHEDULED")
  homeScore      Int?
  awayScore      Int?
  createdAt      DateTime             @default(now())
  awayTeam       Team                 @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam       Team                 @relation("HomeTeam", fields: [homeTeamId], references: [id])
  block          Block?               @relation(fields: [blockId], references: [id])
  category       ChampionshipCategory @relation(fields: [categoryId], references: [id])
  championship   Championship         @relation(fields: [championshipId], references: [id])
}

model Standing {
  id         String               @id @default(uuid())
  teamId     String
  categoryId String
  played     Int                  @default(0)
  wins       Int                  @default(0)
  losses     Int                  @default(0)
  points     Int                  @default(0)
  pointsFor  Int                  @default(0)
  pointsAg   Int                  @default(0)
  category   ChampionshipCategory @relation(fields: [categoryId], references: [id])
  team       Team                 @relation(fields: [teamId], references: [id])

  @@unique([teamId, categoryId])
}

model Document {
  id             String       @id @default(uuid())
  name           String
  type           String
  format         String
  url            String?
  championshipId String
  createdAt      DateTime     @default(now())
  championship   Championship @relation(fields: [championshipId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  teamId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  content    String
  fromTeamId String?
  fromAdmin  Boolean  @default(false)
  createdAt  DateTime @default(now())
  team       Team?    @relation("SentMessages", fields: [fromTeamId], references: [id])
}

model Holiday {
  id   String   @id @default(uuid())
  date DateTime
  name String
  year Int
}

model TeamMembership {
  id          String    @id @default(uuid())
  userId      String    @unique
  teamId      String
  role        String
  status      String    @default("PENDING")
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  team        Team      @relation(fields: [teamId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}
