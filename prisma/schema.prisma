generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  TEAM
}

enum ChampionshipStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  VALIDATING
  SCHEDULING
  REVIEW
  CONFIRMED
  ONGOING
  COMPLETED
}

enum GameStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole @default(TEAM)
  team      Team?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id             String   @id @default(uuid())
  name           String   @unique
  city           String
  state          String   @default("RS")
  responsible    String
  phone          String
  sex            String   // "masculino" ou "feminino"
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  gym            Gym?
  registrations  Registration[]
  homeGames      Game[]   @relation("HomeTeam")
  awayGames      Game[]   @relation("AwayTeam")
  standings      Standing[]
  notifications  Notification[]
  sentMessages   Message[] @relation("SentMessages")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Gym {
  id           String @id @default(uuid())
  name         String
  address      String
  city         String
  capacity     Int
  availability String // "sabado_domingo", "sabado", "domingo"
  canHost      Boolean @default(true)
  teamId       String  @unique
  team         Team    @relation(fields: [teamId], references: [id])
}

model Championship {
  id             String             @id @default(uuid())
  name           String
  description    String?
  sex            String             // "masculino" ou "feminino"
  format         String             @default("todos_contra_todos")
  phases         Int                @default(3)
  minTeamsPerCat Int                @default(3)
  startDate      DateTime?
  endDate        DateTime?
  regDeadline    DateTime
  status         ChampionshipStatus @default(DRAFT)
  categories     ChampionshipCategory[]
  registrations  Registration[]
  games          Game[]
  blocks         Block[]
  documents      Document[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model ChampionshipCategory {
  id             String       @id @default(uuid())
  name           String       // "Sub 12", "Sub 13", etc.
  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  isViable       Boolean      @default(false) // true se >= minTeamsPerCat
  registrations  RegistrationCategory[]
  standings      Standing[]
  games          Game[]

  @@unique([championshipId, name])
}

model Registration {
  id             String       @id @default(uuid())
  championshipId String
  teamId         String
  status         RegistrationStatus @default(PENDING)
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  team           Team         @relation(fields: [teamId], references: [id])
  categories     RegistrationCategory[]
  blockedDates   BlockedDate[]
  observations   String?
  registeredAt   DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([championshipId, teamId])
}

model RegistrationCategory {
  id             String                @id @default(uuid())
  registrationId String
  categoryId     String
  registration   Registration          @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  category       ChampionshipCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([registrationId, categoryId])
}

model BlockedDate {
  id             String       @id @default(uuid())
  registrationId String
  date           DateTime     // O sábado do fim de semana bloqueado
  reason         String?      // "outro_campeonato", "evento", "feriado", etc.
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Block {
  id             String       @id @default(uuid())
  name           String       // "Bloco A", "Bloco B"
  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  categories     String       // JSON array: ["Sub 12", "Sub 13"]
  games          Game[]
}

model Game {
  id             String                @id @default(uuid())
  championshipId String
  categoryId     String
  blockId        String?
  homeTeamId     String
  awayTeamId     String
  phase          Int                   // 1, 2, 3
  dateTime       DateTime
  altDateTime    DateTime?             // Data alternativa (Plano B)
  location       String
  city           String
  status         GameStatus            @default(SCHEDULED)
  homeScore      Int?
  awayScore      Int?
  championship   Championship          @relation(fields: [championshipId], references: [id])
  category       ChampionshipCategory  @relation(fields: [categoryId], references: [id])
  block          Block?                @relation(fields: [blockId], references: [id])
  homeTeam       Team                  @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team                  @relation("AwayTeam", fields: [awayTeamId], references: [id])
  createdAt      DateTime              @default(now())
}

model Standing {
  id         String                @id @default(uuid())
  teamId     String
  categoryId String
  played     Int     @default(0)
  wins       Int     @default(0)
  losses     Int     @default(0)
  points     Int     @default(0)
  pointsFor  Int     @default(0)
  pointsAg   Int     @default(0)
  team       Team                  @relation(fields: [teamId], references: [id])
  category   ChampionshipCategory  @relation(fields: [categoryId], references: [id])

  @@unique([teamId, categoryId])
}

model Document {
  id             String       @id @default(uuid())
  name           String
  type           String       // "relatorio_geral", "tabela_confrontos", "calendario_equipe", "custos", "ata"
  format         String       // "pdf", "docx", "xlsx"
  url            String?
  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id])
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  teamId    String
  title     String
  message   String
  type      String   // "info", "warning", "success", "danger"
  read      Boolean  @default(false)
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  content   String
  fromTeamId String?
  fromAdmin  Boolean @default(false)
  team       Team?   @relation("SentMessages", fields: [fromTeamId], references: [id])
  createdAt  DateTime @default(now())
}

model Holiday {
  id    String   @id @default(uuid())
  date  DateTime
  name  String
  year  Int
}
