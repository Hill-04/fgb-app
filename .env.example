# Database (Turso)
DATABASE_URL="libsql://your-database.turso.io"
DATABASE_AUTH_TOKEN="your-auth-token"

# NextAuth
NEXTAUTH_SECRET="generate-a-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Production example:
# NEXTAUTH_URL="https://your-app.vercel.app"

# FIBA LiveStats integration (optional)
FIBA_LIVESTATS_PORT=8084
FIBA_LIVESTATS_ENABLED=false

# Manual migration endpoint (POST /api/admin/migrate)
MIGRATE_TOKEN=gere_com_openssl_rand_hex_32
SKIP_AUTO_SCHEMA_ENSURE=false
