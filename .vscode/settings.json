{
  // Caminho explícito do Git (corrige "Failed to execute git")
  "git.path": "C:\\Program Files\\Git\\cmd\\git.exe",

  // Auto-push após commit
  "git.postCommitCommand": "push",

  // Permite commit com stage automático
  "git.enableSmartCommit": true,

  // Confirma antes de fazer sync (push)
  "git.confirmSync": false,

  // Permite commit vazio (com mensagem padrão)
  "git.allowEmptyCommits": false,

  // Usa input box para mensagem se vazia
  "git.useCommitInputAsStashMessage": true,

  // Mostra decorações do git inline
  "git.decorations.enabled": true
}
